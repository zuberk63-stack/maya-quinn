NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ADMIN_EMAILS=admin@example.com
CRON_SECRET=change-this-long-random-value
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_TOPIC_FILTER_MODEL=gemini-1.5-flash-latest
TOPIC_FILTER_SCORE_THRESHOLD=65

# Optional, for direct migration application from local tooling only.
# Do not expose this value to the browser.
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
